{
  "name": "slamtec-s2e-tracker",
  "version": "0.1.0",
  "description": "Slamtec RPLIDAR S2E people tracker with 4-point calibration, event zones, and OSC output to TouchDesigner",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "bridge": "make -C bridge",
    "bridge:setup": "bash bridge/setup-sdk.sh",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json --composite false && tsc --noEmit -p tsconfig.web.json --composite false",
    "dist:mac": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "osc": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  },
  "build": {
    "appId": "com.0dot77.slamtec-tracker",
    "productName": "Slamtec S2E Tracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bridge/s2e_bridge",
        "to": "bridge/s2e_bridge"
      }
    ],
    "mac": {
      "target": "dir",
      "category": "public.app-category.utilities",
      "identity": null
    }
  }
}
